---
import { Icon } from 'astro-icon/components'

const iconClass = 'inline-block h-[1em] align-[-0.125em] overflow-visible'
---

<main class="container mx-auto flex max-w-3xl flex-1 flex-col items-center justify-center px-6 text-center text-sm md:text-base">
  <div class="mb-6 md:mb-10">
    <img
      class="rounded-full transition-all duration-100"
      src="/images/avatar.webp"
      alt="Aozaki's avatar"
      width="120"
      height="120"
      loading="lazy"
      decoding="async"
    />
  </div>
  <h1 class="mb-6 text-3xl font-bold text-zinc-200 md:mb-8 md:text-4xl">[ Aozaki ]</h1>

  <div class="bg-[#111729]">
    <p class="mb-3 wrap-break-word md:mb-8">
      <Icon name="fa6-solid:stethoscope" class={iconClass} /> Doctor / <Icon
        name="fa6-solid:heart-pulse"
        class={iconClass}
      />
      Cardiologist / <Icon name="fa6-solid:graduation-cap" class={iconClass} /> MD
    </p>

    <p class="mb-3 md:mb-8">
      <Icon name="fa6-solid:camera-retro" class={iconClass} /> Photographer /
      <Icon name="fa6-solid:headphones-simple" class={iconClass} /> Audiophile /
      <Icon name="fa6-solid:film" class={iconClass} /> Cinephile
    </p>

    <p class="">
      <Icon name="fa6-solid:feather-pointed" class={iconClass} />
      <a href="https://blog.aozaki.cc/" class="">My Blog</a>
      <span class="px-2" />
      <Icon name="fa6-brands:twitter" class={iconClass} />
      <a href="https://310.im/x" target="_blank" rel="noopener noreferrer" class="">Twitter</a>
      <span class="px-2" />
      <Icon name="fa6-brands:mastodon" class={iconClass} />
      <a href="https://310.im/ms" target="_blank" rel="me noopener noreferrer" class="">Mastodon</a>
      <span class="px-2" />
      <Icon name="fa6-brands:github" class={iconClass} />
      <a href="https://310.im/gh" target="_blank" rel="noopener noreferrer" class="">Github</a>
    </p>
  </div>

  <div class="bg-[#111729] text-center">
    <p class="mt-3 md:mt-8">
      <Icon name="fa6-brands:discord" class={iconClass} />
      <a href="https://310.im/dc" target="_blank" rel="me noopener noreferrer" class="">Discord</a>
      <span class="px-2" />
      <Icon name="fa6-brands:telegram" class={iconClass} />
      <a href="https://310.im/tg" target="_blank" rel="me noopener noreferrer" class="">Telegram</a>
    </p>

    <p class="mt-3 md:mt-8">
      <Icon name="fa6-solid:envelope" class={iconClass} /> <a href="mailto:i@aozaki.cc">i#aozaki.cc</a>
    </p>
  </div>
</main>
