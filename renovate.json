{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true
  },
  "packageRules": [
    {
      "description": "运行时资源依赖随站点素材一起更新",
      "matchPackageNames": ["@fontsource/**", "@iconify-json/**", "astro-icon"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "site assets"
    },
    {
      "description": "Astro 栈更新应保持核心与配套插件同步",
      "matchPackageNames": ["astro", "eslint-plugin-astro", "prettier-plugin-astro"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "astro tooling"
    },
    {
      "description": "样式编译链路统一处理，避免 Tailwind 与 PostCSS 脱节",
      "matchPackageNames": [
        "@tailwindcss/**",
        "postcss",
        "prettier-plugin-tailwindcss",
        "tailwindcss"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "styling toolchain"
    },
    {
      "description": "Lint、格式化与提交流程工具一起更新",
      "matchPackageNames": [
        "@eslint/**",
        "@j178/prek",
        "@types/eslint__eslintrc",
        "eslint",
        "eslint-config-prettier",
        "eslint-plugin-prettier",
        "globals",
        "lint-staged",
        "prettier"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "linting and formatting"
    },
    {
      "description": "TypeScript 编译器、类型定义与规则库统一升级",
      "matchPackageNames": ["@types/node", "typescript", "typescript-eslint"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "typescript tooling"
    },
    {
      "matchCurrentVersion": "!/^0/",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
